{"title":"测试","date":"2018-08-03T05:16:43.000Z","excerpt":"Welcome to my blog, enter password to read.","slug":"2018-08-03-测试","comments":false,"tags":["hexo"],"categories":["Blog"],"updated":"2018-08-23T02:43:09.000Z","content":"<script>\n  function doDecrypt(pwd, onError) {\n    console.log(\"in doDecrypt\");\n    var txt = document.getElementById(\"enc_content\").innerHTML;\n    var plantext;\n    try {\n      var bytes = CryptoJS.AES.decrypt(txt, pwd);\n      plaintext = bytes.toString(CryptoJS.enc.Utf8);\n    } catch (err) {\n      if (onError) { onError(err); }\n      return;\n    }\n    document.getElementById(\"enc_content\").innerHTML = plaintext;\n    document.getElementById(\"enc_content\").style.display = \"block\";\n    document.getElementById(\"enc_passwd\").style.display = \"none\";\n  }\n</script>\n<div id=\"enc_passwd\">\n  <div class=\"encrypt\">\n    <script> var onError = function (error) { $(\"#enc_error\")[0].innerHTML = \"密码错误！\"; }; function decrypt() { var passwd = $(\"#enc_passwd input\")[0].value; console.log(passwd); doDecrypt(passwd, onError); } function EnterPress(e) { var e = window.event || e; if (e.keyCode == 13) { decrypt(); } } </script>\n    <input type=\"text\" onkeydown=\"EnterPress\" onkeypress=\"EnterPress(event)\" style=\"/* border-radius: 10px; */border-style: groove;/* border: 0px; */border-bottom: 2px solid #0097a7; /* 下划线效果 */border-top:0px;border-left:0px;border-right:0px;height: 30px;width: 61.8%;cursor: auto;font-size: 102%;color: currentColor;outline: none;text-overflow: initial;background: #66116616;padding-left: 5px\" placeholder=\"输入密码后请按回车\">\n    <div id=\"enc_error\" style=\" display: inline-block; color: #d84527; font: large; \"> </div>\n  </div>\n</div>\n<div id=\"encrypt-blog\" style=\"display:none\">U2FsdGVkX1/N2dT2SVVBNHviyPGylTtlwpp2dmbx2qmtBcUHyLcTO73ywNOgo/KZHV86qRyPhm6784LG5Ook662kM7oQrDtWr4l7U+qSqtv+kFmJl5y2L2UIruXmFkv0sbUshTl6vpy5wvdHAtrdPB+elW/RruGDoflnyTV4vZH9cu/R8ClTHMcFaB8/ddVURUW1J2Jud6czJdIm2QoW