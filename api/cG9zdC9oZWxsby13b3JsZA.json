\">\"net/http\"</span></span><br><span class=\"line\">\t<span class=\"string\">\"os\"</span></span><br><span class=\"line\">\t<span class=\"string\">\"strconv\"</span></span><br><span class=\"line\">\t<span class=\"string\">\"strings\"</span></span><br><span class=\"line\">\t<span class=\"string\">\"sync\"</span></span><br><span class=\"line\">)</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"keyword\">var</span> mu sync.Mutex <span class=\"comment\">// 共享变量</span></span><br><span class=\"line\"><span class=\"keyword\">var</span> count <span class=\"keyword\">int</span></span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">// ServerStart 开始服务器监听</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">func</span> <span class=\"title\">ServerStart</span><span class=\"params\">()</span></span> &#123;</span><br><span class=\"line\">\tfmt.Println(<span class=\"string\">\"WEB START, HTTP LISTEN PORT 2333\"</span>)</span><br><span class=\"line\">\thttp.HandleFunc(<span class=\"string\">\"/\"</span>, UpdateCounterAndPrintMore)</span><br><span class=\"line\">\thttp.HandleFunc(<span class=\"string\">\"/count\"</span>, counter)</span><br><span class=\"line\">\thttp.HandleFunc(<span class=\"string\">\"/drawfun\"</span>, HandleQuest)</span><br><span class=\"line\">\thttp.HandleFunc(<span class=\"string\">\"/code\"</span>, ShowCode)</span><br><span class=\"line\">\tlog.Fatal(http.ListenAndServe(<span class=\"string\">\"10.0.0.103:2333\"</span>, <span class=\"literal\">nil</span>))</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">func</span> <span class=\"title\">counter</span><span class=\"params\">(w http.ResponseWriter, r *http.Request)</span></span> &#123;</span><br><span class=\"line\">\tmu.Lock()</span><br><span class=\"line\">\tfmt.Fprintf(w, <span class=\"string\">\"Count %d\\n\"</span>, count)</span><br><span class=\"line\">\tmu.Unlock()</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">// UpdateCounterAndPrintMore 跟新计数器状态并且打印请求头更多的内容</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">func</span> <span class=\"title\">UpdateCounterAndPrintMore</span><span class=\"params\">(w http.ResponseWriter, r *http.Request)</span></span> &#123;</span><br><span class=\"line\">\tmu.Lock() <span class=\"comment\">//共享变量加锁</span></span><br><span class=\"line\">\tcount++</span><br><span class=\"line\">\tmu.Unlock()</span><br><span class=\"line\">\t<span class=\"comment\">// fmt.Fprintf(w, \"URL.Path=%q\\n\", r.URL.Path)</span></span><br><span class=\"line\">\t<span class=\"comment\">// Request 结构体</span></span><br><span class=\"line\">\tfmt.Fprintf(w, <span class=\"string\">\"%s %s %s\\n\"</span>, r.Method, r.URL, r.Proto)</span><br><span class=\"line\">\t<span class=\"keyword\">for</span> k, v := <span class=\"keyword\">range</span> r.Header &#123;</span><br><span class=\"line\">\t\tfmt.Fprintf(w, <span class=\"string\">\"Header[%q]=%q\\n\"</span>, k, v)</span><br><span class=\"line\">\t&#125;</span><br><span class=\"line\">\tfmt.Fprintf(w, <span class=\"string\">\"Host=%q\\n\"</span>, r.Host)</span><br><span class=\"line\">\tfmt.Fprintf(w, <span class=\"string\">\"RemoteAdd=%q\\n\"</span>, r.RemoteAddr)</span><br><span class=\"line\">\t<span class=\"keyword\">if</span> err := r.ParseForm(); err != <span class=\"literal\">nil</span> &#123; <span class=\"comment\">// 限制作用域</span></span><br><span class=\"line\">\t\tlog.Print(err)</span><br><span class=\"line\">\t&#125;</span><br><span class=\"line\">\t<span class=\"keyword\">for</span> k, v := <span class=\"keyword\">range</span> r.Form &#123;</span><br><span class=\"line\">\t\tfmt.Fprintf(w, <span class=\"string\">\"Form[%q]=%q\\n\"</span>, k, v)</span><br><span class=\"line\">\t&#125;</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">//HandleQuest 处理URL中的?引起的请求</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">func</span> <span class=\"title\">HandleQuest</span><span class=\"params\">(w http.ResponseWriter, r *http.Request)</span></span> &#123;</span><br><span class=\"line\">\tw.Header().Set(<span class=\"string\">\"Content-Type\"</span>, <span class=\"string\">\"image/svg+xml\"</span>) <span class=\"comment\">// 写svg类型文件</span></span><br><span class=\"line\">\t<span class=\"comment\">// width, height, cells, funstring, angle</span></span><br><span class=\"line\">\tquery := r.URL.RawQuery</span><br><span class=\"line\">\tQ := strings.Split(query, <span class=\"string\">\"?\"</span>)</span><br><span class=\"line\">\twidth, height, cells, angle = <span class=\"number\">600</span>, <span class=\"number\">320</span>, <span class=\"number\">100</span>, math.Pi/<span class=\"number\">6</span></span><br><span class=\"line\">\tFunctionstring = <span class=\"string\">\"sin(sqrt(x*x+y*y))/sqrt(x*x+y*y)\"</span></span><br><span class=\"line\">\t<span class=\"keyword\">for</span> _, q := <span class=\"keyword\">range</span> Q &#123;</span><br><span class=\"line\">\t\t<span class=\"keyword\">switch</span> &#123;</span><br><span class=\"line\">\t\t<span class=\"keyword\">case</span> strings.HasPrefix(q, <span class=\"string\">\"width=\"</span>):</span><br><span class=\"line\">\t\t\twidth, _ = strconv.Atoi(q[<span class=\"number\">6</span>:])</span><br><span class=\"line\">\t\t<span class=\"keyword\">case</span> strings.HasPrefix(q, <span class=\"string\">\"height=\"</span>):</span><br><span class=\"line\">\t\t\theight, _ = strconv.Atoi(q[<span class=\"number\">7</span>:])</span><br><span class=\"line\">\t\t<span class=\"keyword\">case</span> strings.HasPrefix(q, <span class=\"string\">\"cells=\"</span>):</span><br><span class=\"line\">\t\t\tcells, _ = strconv.Atoi(q[<span class=\"number\">6</span>:])</span><br><span class=\"line\">\t\t<span class=\"keyword\">case</span> strings.HasPrefix(q, <span class=\"string\">\"angle=\"</span>):</span><br><span class=\"line\">\t\t\tangle, _ = strconv.ParseFloat(q[<span class=\"number\">6</span>:], <span class=\"number\">64</span>)</span><br><span class=\"line\">\t\t\t<span class=\"comment\">// angle /= 360</span></span><br><span class=\"line\">\t\t<span class=\"keyword\">case</span> strings.HasPrefix(q, <span class=\"string\">\"func=\"</span>):</span><br><span class=\"line\">\t\t\tFunctionstring = q[<span class=\"number\">5</span>:]</span><br><span class=\"line\">\t\t&#125;</span><br><span class=\"line\">\t&#125;</span><br><span class=\"line\">\tsin30, cos30 = math.Sin(angle), math.Cos(angle)</span><br><span class=\"line\"></span><br><span class=\"line\">\tfmt.Printf(<span class=\"string\">\"请求 width=%d height=%d cells=%d angle=%f\\n\"</span>, width, height, cells, angle)</span><br><span class=\"line\">\tfmt.Printf(<span class=\"string\">\"函数: %s\\n\"</span>, Functionstring)</span><br><span class=\"line\"></span><br><span class=\"line\">\tf, _ := os.Create(<span class=\"string\">\"fun_sample.svg\"</span>)</span><br><span class=\"line\">\twg.Add(cells * cells)</span><br><span class=\"line\">\tSurface(f)</span><br><span class=\"line\">\twg.Wait()</span><br><span class=\"line\"></span><br><span class=\"line\">\tfmt.Fprintln(f, <span class=\"string\">\"&lt;/svg&gt;\"</span>)</span><br><span class=\"line\">\tfmt.Println(<span class=\"string\">\"完成绘制任务\"</span>)</span><br><span class=\"line\">\t</span><br><span class=\"line\">\tf, _ = os.Open(<span class=\"string\">\"fun_sample.svg\"</span>)</span><br><span class=\"line\">\tio.Copy(w, f)</span><br><span class=\"line\">\tf.Close()</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"comment\">// ShowCode 响应源码请求</span></span><br><span class=\"line\"><span class=\"function\"><span class=\"keyword\">func</span> <span class=\"title\">ShowCode</span><span class=\"params\">(w http.ResponseWriter, f *http.Request)</span></span> &#123;</span><br><span class=\"line\">\tfileF, _ := os.Open(<span class=\"string\">\"code.txt\"</span>)</span><br><span class=\"line\">\tinput := bufio.NewScanner(fileF)</span><br><span class=\"line\">\t<span class=\"keyword\">for</span> input.Scan() &#123;</span><br><span class=\"line\">\t\tfmt.Fprintln(w, input.Text())</span><br><span class=\"line\">\t&#125;</span><br><span class=\"line\">&#125;</span><br></pre></td></tr></table></figure>\n<p>More info: <a href=\"https://hexo.io/docs/deployment.html\" target=\"_blank\" rel=\"noopener\">Deployment</a></p>\n","link":"/2018/07/21","toc":[{"title":"Quick Start","id":"Quick-Start","index":"1","children":[{"title":"Create a new post","id":"Create-a-new-post","index":"1.1"},{"title":"Run server","id":"Run-server","index":"1.2"},{"title":"Generate static files","id":"Generate-static-files","index":"1.3"},{"title":"Deploy to remote sites","id":"Deploy-to-remote-sites","index":"1.4"},{"title":"测试LaTeX","id":"测试LaTeX","index":"1.5"},{"title":"测试Code","id":"测试Code","index":"1.6"}]}]}